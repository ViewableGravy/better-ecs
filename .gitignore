# Prevent compiled output in source directories
# (build output belongs in dist/, not src/)
src/**/*.types/**/*.d.ts
src/**/*.types/**/*.d.ts.map

# But allow spec/test JS files if any exist
!packages/*/src/**/*.spec.*
!packages/*/src/**/*.test.*

# Ignore playwright last run json files
.last-run.json
