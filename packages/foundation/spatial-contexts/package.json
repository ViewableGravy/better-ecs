{
  "name": "@repo/spatial-contexts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./portal": {
      "types": "./dist/portal/index.d.ts",
      "default": "./dist/portal/index.js"
    }
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.lib.json",
    "clean": "rm -rf dist tsconfig.lib.tsbuildinfo",
    "lint": "bun x eslint .",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun x vitest run"
  },
  "dependencies": {
    "@repo/engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
