{
  "name": "@repo/hmr",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.lib.json",
    "clean": "rm -rf dist tsconfig.lib.tsbuildinfo",
    "lint": "bun x eslint .",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}
