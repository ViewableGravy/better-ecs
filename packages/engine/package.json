{
  "name": "@repo/engine",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./context": {
      "types": "./src/context/index.ts",
      "default": "./src/context/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./context-utils": {
      "types": "./src/context-utils/index.ts",
      "default": "./src/context-utils/index.ts"
    },
    "./internal/utils": {
      "types": "./src/internal/utils/index.ts",
      "default": "./src/internal/utils/index.ts"
    },
    "./ecs/hierarchy": {
      "types": "./src/ecs/hierarchy.ts",
      "default": "./src/ecs/hierarchy.ts"
    },
    "./render": {
      "types": "./src/render/index.ts",
      "default": "./src/render/index.ts"
    },
    "./asset": {
      "types": "./src/asset/index.ts",
      "default": "./src/asset/index.ts"
    },
    "./texture": {
      "types": "./src/texture/index.ts",
      "default": "./src/texture/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    }
  },
  "scripts": {
    "build": "npx tsc -p tsconfig.lib.json && bun x tsc-alias -p tsconfig.lib.json && bun x vite build --config vite.config.ts",
    "clean": "rm -rf dist tsconfig.lib.tsbuildinfo",
    "lint": "bun x eslint .",
    "typecheck": "npx tsc --noEmit",
    "test": "vitest --run --typecheck"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@phosphor-icons/react": "^2.1.10",
    "@repo/utils": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "classnames": "^2.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tiny-invariant": "^1.3.3",
    "type-fest": "^4.9.0",
    "valtio": "^2.3.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
