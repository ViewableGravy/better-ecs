{
  "name": "engine",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/engine/src",
  "projectType": "library",
  "tags": ["type:engine"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc -p tsconfig.lib.json && bun x vite build --config vite.config.ts",
        "cwd": "packages/engine"
      },
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/dist"]
    },
    "build:watch": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "commands": [
          "npx tsc -p tsconfig.lib.json --watch",
          "bun x vite build --config vite.config.ts --watch"
        ],
        "cwd": "packages/engine"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist tsconfig.lib.tsbuildinfo",
        "cwd": "packages/engine"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "packages/engine"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x eslint .",
        "cwd": "packages/engine"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest --run --typecheck",
        "cwd": "packages/engine"
      }
    }
  }
}
