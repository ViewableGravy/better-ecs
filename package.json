{
  "name": "@repo/root",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "extend-tsconfigs": "bun scripts/ts-extend-paths/extend-tsconfigs.mjs",
    "postinstall": "bun extend-tsconfigs",
    "predev": "test -x node_modules/.bin/nx || bun install",
    "preclient:dev": "test -x node_modules/.bin/nx || bun install",
    "preserver:dev": "test -x node_modules/.bin/nx || bun install",
    "dev": "bun x vite --config vite.config.ts",
    "client:dev": "bun x vite --config vite.config.ts",
    "server:dev": "NX_DAEMON=false nx run server:dev",
    "build": "bun x vite build --config vite.config.ts",
    "build:all": "bun x vite build --config vite.config.ts --force",
    "lint": "nx run-many --target=lint",
    "typecheck": "nx run-many --target=typecheck",
    "test": "nx run-many --target=test",
    "e2e": "bun x playwright test --config=src/app/client/playwright.config.ts",
    "clean": "nx run-many --target=clean",
    "clean:all": "rm -rf dist .nx/cache && nx run-many --target=clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "^22.3.3",
    "@nx/eslint-plugin": "22.3.3",
    "@nx/jest": "22.3.3",
    "@nx/rollup": "^22.3.3",
    "@nx/vite": "^22.3.3",
    "@nx/vitest": "22.3.3",
    "@nx/web": "22.3.3",
    "@playwright/test": "^1.58.2",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "ajv": "^8.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "^22.3.3",
    "playwright": "^1.58.1",
    "prettier": "~3.6.2",
    "sass": "^1.97.3",
    "skott": "^0.35.7",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@nx/js": "^22.3.3",
    "@standard-schema/spec": "^1.1.0",
    "@headlessui/react": "^2.2.9",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.90.21",
    "classnames": "^2.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tiny-invariant": "^1.3.3",
    "type-fest": "^5.4.4",
    "valtio": "^2.3.0",
    "zod": "^4.3.4"
  }
}
