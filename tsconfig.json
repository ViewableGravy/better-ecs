{
  "extends": "./tsconfig.base.json",
  "files": [],
  "include": [],
  "compilerOptions": {
    "experimentalDecorators": true,
    "paths": {
      "@client": [
        "./src/app/client/src/index.ts"
      ],
      "@client/*": [
        "./src/app/client/src/*"
      ],
      "@server": [
        "./src/app/server/src/main.ts"
      ],
      "@server/*": [
        "./src/app/server/src/*"
      ],
      "@libs/commands": [
        "./src/libs/commands/src/index.ts"
      ],
      "@libs/commands/*": [
        "./src/libs/commands/src/*"
      ],
      "@libs/fps": [
        "./src/libs/fps/src/index.ts"
      ],
      "@libs/fps/*": [
        "./src/libs/fps/src/*"
      ],
      "@libs/networking": [
        "./src/libs/networking/src/index.ts"
      ],
      "@libs/networking/*": [
        "./src/libs/networking/src/*"
      ],
      "@libs/physics": [
        "./src/libs/physics/src/index.ts"
      ],
      "@libs/physics/*": [
        "./src/libs/physics/src/*"
      ],
      "@libs/spatial-contexts": [
        "./src/libs/spatial-contexts/src/index.ts"
      ],
      "@libs/spatial-contexts/*": [
        "./src/libs/spatial-contexts/src/*"
      ],
      "@libs/state-sync": [
        "./src/libs/state-sync/src/index.ts"
      ],
      "@libs/state-sync/*": [
        "./src/libs/state-sync/src/*"
      ],
      "@utils": [
        "./src/utils/src/index.ts"
      ],
      "@utils/*": [
        "./src/utils/src/*"
      ],
      "@engine": [
        "./src/engine/src/index.ts"
      ],
      "@engine/*": [
        "./src/engine/src/*"
      ],
      "@hmr": [
        "./vite/engine-hmr/index.ts"
      ],
      "@hmr/*": [
        "./vite/engine-hmr/*"
      ],
      "@repo/networking": [
        "./src/libs/networking/src/index.ts"
      ],
      "@repo/networking/*": [
        "./src/libs/networking/src/*"
      ]
    }
  },
  "references": [
    {
      "path": "./src/utils"
    },
    {
      "path": "./src/engine"
    },
    {
      "path": "./src/libs/commands"
    },
    {
      "path": "./src/libs/physics"
    },
    {
      "path": "./src/libs/spatial-contexts"
    },
    {
      "path": "./src/libs/fps"
    },
    {
      "path": "./src/libs/networking"
    },
    {
      "path": "./vite/engine-hmr"
    },
    {
      "path": "./src/app/client"
    },
    {
      "path": "./src/app/server"
    }
  ],
  "exclude": [
    "**/dist",
    "**/src/**/dist",
    "**/node_modules/*"
  ]
}
