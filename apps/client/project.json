{
  "name": "client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/client/src",
  "projectType": "application",
  "tags": ["type:client"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "commands": [
          "NX_DAEMON=false bun x nx run-many --target=build:watch --projects=$(bun x nx graph --print | jq -r '[.graph.dependencies[\"client\"][]?.target] | unique | join(\",\")') --outputStyle=static",
          "bun run dev"
        ],
        "cwd": "apps/client"
      }
    },
    "build-deps": {
      "executor": "nx:noop",
      "dependsOn": ["^build"],
      "options": {}
    },
    "watch-deps": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["build-deps"],
      "options": {
        "command": "bun x nx run-many --target=build:watch --projects=$(bun x nx graph --print | jq -r --arg project \"{projectName}\" '[.graph.dependencies[$project][]?.target] | unique | join(\",\")') --outputStyle=static",
        "cwd": "."
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run build",
        "cwd": "apps/client"
      },
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/dist"]
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist",
        "cwd": "apps/client"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run preview",
        "cwd": "apps/client"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x eslint .",
        "cwd": "apps/client"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "apps/client"
      }
    }
  }
}
