{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "composite": false,
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "references": [
    {
      "path": "../../packages/utils"
    },
    {
      "path": "../../packages/foundation/spatial-contexts"
    },
    {
      "path": "../../packages/foundation/physics"
    },
    {
      "path": "../../packages/tooling/hmr"
    },
    {
      "path": "../../packages/features/fps"
    },
    {
      "path": "../../packages/engine"
    }
  ]
}
