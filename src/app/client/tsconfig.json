{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "skipLibCheck": true,
    "composite": false,
    "strict": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["e2e/**/*"],
  "references": [
    {
      "path": "../../utils/tsconfig.lib.json"
    },
    {
      "path": "../../libs/spatial-contexts/tsconfig.lib.json"
    },
    {
      "path": "../../libs/physics/tsconfig.lib.json"
    },
    {
      "path": "../../../vite/engine-hmr/tsconfig.lib.json"
    },
    {
      "path": "../../libs/fps/tsconfig.lib.json"
    },
    {
      "path": "../../engine/tsconfig.lib.json"
    }
  ]
}
