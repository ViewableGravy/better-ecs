{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "DOM",
      "ES2022"
    ],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "typeRoots": [
      "../../node_modules/@types"
    ],
    "paths": {
      "@client": [
        "./src/app/client/src/index.ts"
      ],
      "@client/*": [
        "./src/app/client/src/*"
      ],
      "@server": [
        "./src/app/server/src/main.ts"
      ],
      "@server/*": [
        "./src/app/server/src/*"
      ],
      "@libs/fps": [
        "./src/libs/fps/src/index.ts"
      ],
      "@libs/fps/*": [
        "./src/libs/fps/src/*"
      ],
      "@libs/physics": [
        "./src/libs/physics/src/index.ts"
      ],
      "@libs/physics/*": [
        "./src/libs/physics/src/*"
      ],
      "@libs/spatial-contexts": [
        "./src/libs/spatial-contexts/src/index.ts"
      ],
      "@libs/spatial-contexts/*": [
        "./src/libs/spatial-contexts/src/*"
      ],
      "@utils": [
        "./src/utils/src/index.ts"
      ],
      "@utils/*": [
        "./src/utils/src/*"
      ],
      "@engine": [
        "./src/engine/src/index.ts"
      ],
      "@engine/*": [
        "./src/engine/src/*"
      ],
      "@ui": [
        "./src/ui/index.tsx"
      ],
      "@ui/*": [
        "./src/ui/*"
      ]
    }
  },
  "files": [],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
