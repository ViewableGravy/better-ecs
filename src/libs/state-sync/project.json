{
  "name": "state-sync",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src/libs/state-sync/src",
  "projectType": "library",
  "tags": ["type:foundation", "domain:state-sync"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x tsc -p tsconfig.lib.json --emitDeclarationOnly",
        "cwd": "src/libs/state-sync"
      },
      "inputs": ["default", "^default"]
    },
    "build:watch": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x tsc -p tsconfig.lib.json --watch",
        "cwd": "src/libs/state-sync"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf .types dist tsconfig.lib.tsbuildinfo",
        "cwd": "src/libs/state-sync"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x eslint .",
        "cwd": "src/libs/state-sync"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x tsc --noEmit",
        "cwd": "src/libs/state-sync"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x vitest run",
        "cwd": "src/libs/state-sync"
      }
    }
  }
}