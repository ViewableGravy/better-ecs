{
  "name": "utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src/utils/src",
  "projectType": "library",
  "tags": ["type:utils"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist && bun x tsc -p tsconfig.lib.json",
        "cwd": "src/utils"
      },
      "outputs": ["{projectRoot}/dist"],
      "inputs": ["default", "^default"]
    },
    "build:watch": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x tsc -p tsconfig.lib.json --watch",
        "cwd": "src/utils"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist",
        "cwd": "src/utils"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun x eslint .",
        "cwd": "src/utils"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "src/utils"
      }
    }
  }
}
